pipeline {
  agent any

  stages {

    stage('Hello') {
      steps {
        echo 'Hello World'
      }
    }

    stage('fileCreate') {
        agent { label 'agent2' }
        steps {
        writeFile file: 'test.txt', text: 'Jenkins learning!'
        sh 'ls -l'
        sh 'pwd'
      }
    }
    stage('fileCreateInHome') {
        agent { label 'agent' }
        steps {
            sh "echo 'Hii Adarsha In Home Dir' > /home/adev4769_gmail_com/test.txt"
            }
        }
    }
}